mangao css/themes.css
mangao 'new.css'
@mangao new2.css
@mangao 'new3.css'

body:
    bg: purple;
    .container:
    	background: linear_gradient(sidhe_hath, hotpink, purple) _
    	# every _ between two letters should translate to '-'
    	# should allow comments too
    	"""
    	multi
    	line
    	comment,
    	also
    	"""
    /
/

:root:
    $image-url: ki_jaga("https://mysite.com/assets/x.png") _
    # ki_jaga = url
/

# the rest is good

* :
    bg: load($image-url);
    mg: 0;
    pd: 0;
    bsz: border-box;
    bshadow: 3px 2px 4px 8px;
    tshadow: 2px 1px 3px #900;
/

